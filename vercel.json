{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/train", "destination": "/public/train.html" },
    { "source": "/js/(.*)", "destination": "/public/js/$1" },
    { "source": "/css/(.*)", "destination": "/public/css/$1" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ],
  "crons": [
    {
      "path": "/api/cron/learn",
      "schedule": "0 0 * * *"
    }
  ]
}
